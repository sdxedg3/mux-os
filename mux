#!/bin/bash
# Mux-OS MVP — Android App Launcher via Termux
# Forked from: https://github.com/DreaM117er/mux-os
# License: MIT

MUX_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
APP_CSV="$MUX_ROOT/app.csv"

C_RESET="\033[0m"
C_GREEN="\033[1;32m"
C_YELLOW="\033[1;33m"
C_RED="\033[1;31m"
C_CYAN="\033[1;36m"
C_GRAY="\033[1;30m"

# ── CSV parser ──────────────────────────────────────────────────

# Global arrays indexed by command name
declare -A CMD_PKG CMD_TARGET CMD_ENGINE CMD_TYPE

parse_csv() {
    CMD_PKG=()
    CMD_TARGET=()
    CMD_ENGINE=()
    CMD_TYPE=()
    while IFS=',' read -r raw_cmd raw_type raw_pkg raw_target raw_engine || [ -n "$raw_cmd" ]; do
        # Skip comments and empty lines
        [[ "$raw_cmd" =~ ^#.*$ || -z "$raw_cmd" ]] && continue
        local cmd=$(echo "$raw_cmd" | tr -d ' "')
        local type=$(echo "$raw_type" | tr -d ' "')
        local pkg=$(echo "$raw_pkg" | tr -d ' "')
        local target=$(echo "$raw_target" | tr -d ' "')
        local engine=$(echo "$raw_engine" | tr -d ' "')
        CMD_TYPE["$cmd"]="$type"
        CMD_PKG["$cmd"]="$pkg"
        CMD_TARGET["$cmd"]="$target"
        CMD_ENGINE["$cmd"]="$engine"
    done < "$APP_CSV"
}

# ── Security guard ───────────────────────────────────────────────

security_check() {
    local payload="$*"
    # Block su/root escalation
    if [[ "$payload" =~ ^(su|tsu|sudo)[[:space:]] ]]; then
        echo -e "${C_RED}✗ Blocked: root escalation not allowed${C_RESET}" >&2
        return 1
    fi
    # Block destructive patterns
    if [[ "$payload" =~ (rm[[:space:]]+-rf[[:space:]]+/|mkfs|dd[[:space:]]+if=) ]]; then
        echo -e "${C_RED}✗ Blocked: destructive command detected${C_RESET}" >&2
        return 1
    fi
    return 0
}

# ── App launcher ─────────────────────────────────────────────────

launch_app() {
    local cmd="$1"
    shift
    local query="$*"

    local pkg="${CMD_PKG["$cmd"]}"
    local target="${CMD_TARGET["$cmd"]}"
    local type="${CMD_TYPE["$cmd"]}"
    local engine="${CMD_ENGINE["$cmd"]}"

    if [ -z "$pkg" ] && [ -z "$engine" ]; then
        echo -e "${C_RED}✗ Unknown command: ${cmd}${C_RESET}"
        echo "  Run 'mux' to see available commands."
        return 1
    fi

    # Build intent
    if [ "$type" == "NB" ] && [ -n "$query" ]; then
        # Search mode: use search engine
        if [ -n "$engine" ]; then
            local safe_query="${query// /+}"
            local url="${engine}${safe_query}"
            echo -e "${C_GRAY}  → Search: ${query}${C_RESET}"
            nohup am start --user 0 -a android.intent.action.VIEW -d "$url" >/dev/null 2>&1 &
        else
            echo -e "${C_RED}✗ No search engine configured for: ${cmd}${C_RESET}" >&2
            return 1
        fi
    else
        # Direct launch: -n pkg/target or -p pkg, run in background
        if [ -n "$target" ]; then
            nohup am start --user 0 -n "$pkg/$target" >/dev/null 2>&1 &
        else
            nohup am start --user 0 -p "$pkg" >/dev/null 2>&1 &
        fi
        echo -e "${C_GREEN}✓ ${cmd}${C_RESET}"
    fi
}

# ── List available commands ──────────────────────────────────────

list_commands() {
    echo -e "${C_CYAN}Available commands:${C_RESET}"
    local cmds=()
    while IFS=',' read -r raw_cmd raw_type raw_pkg rest || [ -n "$raw_cmd" ]; do
        [[ "$raw_cmd" =~ ^#.*$ || -z "$raw_cmd" ]] && continue
        cmds+=("$(echo "$raw_cmd" | tr -d ' "')")
    done < "$APP_CSV"
    printf "  ${C_GREEN}%s${C_RESET} " "${cmds[@]}"
    echo ""
}

# ── Tools ────────────────────────────────────────────────────────

RISH_BIN="/data/data/com.termux/files/usr/bin/rish"
RISH_READY=""

rish_check() {
    [ -n "$RISH_READY" ] && return 0
    if [ -x "$RISH_BIN" ] && timeout 10 "$RISH_BIN" -c "echo ok" 2>/dev/null | grep -q "ok"; then
        RISH_READY=1
        return 0
    fi
    echo -e "${C_RED}✗ Shizuku not available. Start it with 'shizuku' first.${C_RESET}" >&2
    return 1
}

cmd_ps() {
    rish_check || return 1
    echo -e "${C_CYAN}Running app processes:${C_RESET}"
    echo -e "${C_GRAY}  PID  USER         APP${C_RESET}"
    "$RISH_BIN" -c "
      ps -ef 2>/dev/null | awk '\$8 ~ /^com\./ || \$8 ~ /^moe\.shizuku/ || \
        \$8 ~ /^li\.songe/ || \$8 ~ /^org\.chromium/ {
          printf \"  %-5s %-12s %s\\n\", \$2, \$1, \$8
        }'
    " 2>/dev/null | head -40
}

cmd_top() {
    rish_check || return 1
    echo -e "${C_CYAN}System resources:${C_RESET}"
    "$RISH_BIN" -c "
      echo '--- Memory ---'
      memtotal=\$(awk '/MemTotal/ {printf \"%.0f\", \$2/1024}' /proc/meminfo)
      memfree=\$(awk '/MemAvailable/ {printf \"%.0f\", \$2/1024}' /proc/meminfo)
      memused=\$((memtotal - memfree))
      echo \"  Total: \${memtotal}MB  Used: \${memused}MB  Free: \${memfree}MB\"
      echo ''
      echo '--- Top CPU consumers ---'
      top -n 1 -b 2>/dev/null | head -12
    " 2>/dev/null
}

cmd_screencap() {
    rish_check || return 1
    local filename="mux_$(date +%Y%m%d_%H%M%S).png"
    local dest="/sdcard/Pictures/Screenshots/${filename}"
    echo -e "${C_YELLOW}→ Capturing screenshot...${C_RESET}"
    if "$RISH_BIN" -c "
      screencap -p '${dest}' && \
      am broadcast -a android.intent.action.MEDIA_SCANNER_SCAN_FILE \
        -d file://${dest} > /dev/null 2>&1 && \
      echo OK
    " 2>/dev/null | grep -q "OK"; then
        echo -e "${C_GREEN}✓ Screenshot saved → ${dest}${C_RESET}"
    else
        # Fallback to /sdcard/
        dest="/sdcard/${filename}"
        if "$RISH_BIN" -c "
          screencap -p '${dest}' && \
          am broadcast -a android.intent.action.MEDIA_SCANNER_SCAN_FILE \
            -d file://${dest} > /dev/null 2>&1 && \
          echo OK
        " 2>/dev/null | grep -q "OK"; then
            echo -e "${C_GREEN}✓ Screenshot saved → ${dest}${C_RESET}"
        else
            echo -e "${C_RED}✗ Screenshot failed${C_RESET}"
            return 1
        fi
    fi
}

cmd_notify() {
    local title="${1:-Mux-OS}"
    local content="${2:-Hello from Mux-OS!}"
    if command -v termux-notification > /dev/null 2>&1; then
        termux-notification --title "$title" --content "$content" --id mux-os > /dev/null 2>&1
        echo -e "${C_GREEN}✓ Notification sent${C_RESET}"
    else
        echo -e "${C_RED}✗ termux-notification not found${C_RESET}"
        echo "  Install Termux:API from F-Droid and run: pkg install termux-api"
        return 1
    fi
}

# ── Help ──────────────────────────────────────────────────────────

cmd_help() {
    echo -e "${C_CYAN}Mux-OS${C_RESET} — Android App Launcher & Tools"
    echo ""
    echo -e "  ${C_GREEN}mux${C_RESET}                 List available apps"
    echo -e "  ${C_GREEN}mux <app>${C_RESET}            Launch an app"
    echo -e "  ${C_GREEN}mux <app> <query>${C_RESET}     Search in app or web"
    echo ""
    echo -e "  ${C_GREEN}mux ps${C_RESET}               List running app processes"
    echo -e "  ${C_GREEN}mux top${C_RESET}               Show CPU/memory overview"
    echo -e "  ${C_GREEN}mux screencap${C_RESET}         Take a screenshot"
    echo -e "  ${C_GREEN}mux notify [title] [msg]${C_RESET}  Send a notification"
    echo -e "  ${C_GREEN}mux kill <app>${C_RESET}        Force-stop an app (Shizuku)"
    echo ""
    list_commands
}

# ── Main ─────────────────────────────────────────────────────────

main() {
    parse_csv

    case "${1:-}" in
        help|--help|-h)
            cmd_help
            ;;
        "")
            cmd_help
            ;;
        kill)
            shift
            "$MUX_ROOT/mux-kill.sh" "$@"
            ;;
        ps)
            cmd_ps
            ;;
        top)
            cmd_top
            ;;
        screencap|sc)
            cmd_screencap
            ;;
        notify|notification)
            shift
            cmd_notify "$@"
            ;;
        *)
            security_check "$@" || exit 1
            launch_app "$@"
            ;;
    esac
}

# When sourced, only define functions (no execution)
# When run as 'mux', call main with arguments
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
